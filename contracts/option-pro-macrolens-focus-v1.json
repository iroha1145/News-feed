{
  "$defs": {
    "FocusSymbol": {
      "additionalProperties": false,
      "properties": {
        "as_of": {"format": "date-time", "title": "As Of", "type": "string"},
        "breakout_state": {
          "anyOf": [{"maxLength": 60, "type": "string"}, {"type": "null"}],
          "default": null,
          "title": "Breakout State"
        },
        "data_quality": {
          "anyOf": [{"maximum": 1, "minimum": 0, "type": "number"}, {"type": "null"}],
          "default": null,
          "title": "Data Quality"
        },
        "data_status": {
          "default": "active",
          "enum": ["active", "stale"],
          "title": "Data Status",
          "type": "string"
        },
        "dollar_volume_rank": {
          "anyOf": [{"minimum": 1, "type": "integer"}, {"type": "null"}],
          "default": null,
          "title": "Dollar Volume Rank"
        },
        "rvol_time_of_day": {
          "anyOf": [{"minimum": 0, "type": "number"}, {"type": "null"}],
          "default": null,
          "title": "Rvol Time Of Day"
        },
        "sector_id": {
          "anyOf": [{"maxLength": 120, "type": "string"}, {"type": "null"}],
          "default": null,
          "title": "Sector Id"
        },
        "session_change_pct": {
          "anyOf": [{"type": "number"}, {"type": "null"}],
          "default": null,
          "title": "Session Change Pct"
        },
        "ticker": {
          "maxLength": 20,
          "minLength": 1,
          "pattern": "^[A-Z0-9][A-Z0-9.^/_-]{0,19}$",
          "title": "Ticker",
          "type": "string"
        },
        "universe_reasons": {
          "items": {"type": "string"},
          "maxItems": 12,
          "minItems": 1,
          "title": "Universe Reasons",
          "type": "array"
        },
        "validation_status": {
          "enum": ["canonical", "valid_external", "unverified"],
          "title": "Validation Status",
          "type": "string"
        }
      },
      "required": ["ticker", "validation_status", "universe_reasons", "as_of"],
      "title": "FocusSymbol",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "as_of": {"format": "date-time", "title": "As Of", "type": "string"},
    "data_through": {
      "anyOf": [{"format": "date-time", "type": "string"}, {"type": "null"}],
      "default": null,
      "title": "Data Through"
    },
    "major_market_symbols": {
      "items": {
        "maxLength": 20,
        "minLength": 1,
        "pattern": "^[A-Z0-9][A-Z0-9.^/_-]{0,19}$",
        "type": "string"
      },
      "maxItems": 20,
      "title": "Major Market Symbols",
      "type": "array"
    },
    "market_session": {
      "enum": ["premarket", "regular", "after_hours", "closed", "unknown"],
      "title": "Market Session",
      "type": "string"
    },
    "revision": {"minimum": 1, "title": "Revision", "type": "integer"},
    "schema_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Schema Sha256",
      "type": "string"
    },
    "schema_version": {
      "const": "option-pro-macrolens-focus-v1",
      "default": "option-pro-macrolens-focus-v1",
      "title": "Schema Version",
      "type": "string"
    },
    "symbols": {
      "items": {"$ref": "#/$defs/FocusSymbol"},
      "maxItems": 200,
      "title": "Symbols",
      "type": "array"
    },
    "universe_version": {
      "maxLength": 200,
      "minLength": 1,
      "title": "Universe Version",
      "type": "string"
    },
    "warnings": {
      "items": {"type": "string"},
      "maxItems": 50,
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "schema_sha256",
    "as_of",
    "market_session",
    "universe_version",
    "revision"
  ],
  "title": "FocusContextResponse",
  "type": "object"
}
