# Generate a long random value and keep it on the two backend servers only.
# Internal endpoints remain unavailable while this is blank.
INTERNAL_API_TOKEN=

# Optional paid news sources. Missing keys are reported as not_configured.
FINNHUB_API_KEY=
MASSIVE_API_KEY=
NEWSAPI_API_KEY=
GNEWS_API_KEY=

# Machine-local paths and binding. Keep the default bind unless a private
# Tailscale or WireGuard address is intentionally configured.
DATA_DIR=/app/data
HOST_BIND=127.0.0.1
PORT=8000
