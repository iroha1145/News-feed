# MacroLens configuration template
# Copy this file to .env. Never commit the populated .env file.

# --- Administrator access ---
# Use a long random value. setup.sh generates one automatically.
ADMIN_TOKEN=
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=28800

# --- News-source credentials ---
FINNHUB_API_KEY=
MASSIVE_API_KEY=
NEWSAPI_API_KEY=
GNEWS_API_KEY=

# Sources with a missing API key report "not_configured" instead of failing.
FINNHUB_NEWS_ENABLED=true
FINNHUB_NEWS_INTERVAL=300
MASSIVE_NEWS_ENABLED=true
MASSIVE_NEWS_INTERVAL=3600

# Keyless RSS sources. Keep the daily feed on a deliberately slow schedule.
GOOGLE_NEWS_ENABLED=true
GOOGLE_NEWS_INTERVAL=900
SEEKINGALPHA_BREAKING_ENABLED=true
SEEKINGALPHA_BREAKING_INTERVAL=300
SEEKINGALPHA_DAILY_ENABLED=true
SEEKINGALPHA_DAILY_INTERVAL=21600

# These overlap heavily with the core feeds and have tight entry-plan quotas,
# so they remain disabled unless explicitly needed.
NEWSAPI_NEWS_ENABLED=false
NEWSAPI_NEWS_INTERVAL=1800
GNEWS_NEWS_ENABLED=false
GNEWS_NEWS_INTERVAL=1800
FINNHUB_FOCUS_INTERVAL=1800
MASSIVE_FOCUS_INTERVAL=2700

# --- Model analysis ---
# Supported providers: openai, anthropic, grok, ollama
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-5.6-terra
DEFAULT_LLM_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ALLOW_CUSTOM_BASE_URL=false
OPENAI_ALLOW_LOCAL_HTTP=false
OPENAI_REASONING=max
OPENAI_EXECUTION_MODE=background
OPENAI_SYNC_TIMEOUT_SECONDS=900
OPENAI_BACKGROUND_POLL_TIMEOUT_SECONDS=1800
OPENAI_BACKGROUND_INITIAL_POLL_SECONDS=2
OPENAI_BACKGROUND_MAX_POLL_SECONDS=15
OPENAI_MAX_OUTPUT_TOKENS=128000
OPENAI_MAX_CONCURRENCY=2
OPENAI_MAX_RETRIES=0
NEWS_IMPACT_PROMPT_VERSION=news-impact-v2
NEWS_IMPACT_SCHEMA_VERSION=news-impact-schema-v2
NEWS_LLM_AUTO_ANALYZE_ENABLED=false
NEWS_ITEM_MAX_OUTPUT_TOKENS=32768
NEWS_LLM_MAX_INFLIGHT=2
NEWS_LLM_MAX_QUEUED=200
NEWS_LLM_DAILY_JOB_LIMIT=
NEWS_LLM_DAILY_OUTPUT_TOKEN_LIMIT=
NEWS_LLM_MANUAL_ENABLED=false
NEWS_LLM_MANUAL_DAILY_JOB_LIMIT=
NEWS_LLM_MANUAL_DAILY_OUTPUT_TOKEN_LIMIT=
HOT_CYCLE_ENABLED=false
HOT_CYCLE_SCHEDULE_ENABLED=false
HOT_CYCLE_TIMES_ET=08:00,12:00,16:00
HOT_CYCLE_OPTIONAL_20_ET=false
HOT_CYCLE_MANUAL_ENABLED=false
HOT_CYCLE_MAX_EVENTS=8
HOT_CYCLE_MAX_FOCUS_SYMBOLS=20
HOT_CYCLE_MAX_OUTPUT_TOKENS=49152
HOT_CYCLE_DAILY_JOB_LIMIT=
HOT_CYCLE_DAILY_OUTPUT_TOKEN_LIMIT=
# One-time recovery is opt-in per cycle. Keep this empty list unless the exact
# official OpenAI 400 response and all row fingerprints were independently verified.
MARKET_FOCUS_LEGACY_RECOVERY_AUTHORIZATIONS=[]
# Display-only Catalyst context calibration; it never changes formal scores.
CATALYST_CONTEXT_SUPPORT_TARGET=80
NEWS_LLM_MIN_CONTEXT_CHARS=100
NEWS_LLM_MIN_MARKET_RELEVANCE=35
ANALYSIS_WORKER_POLL_SECONDS=5
ANALYSIS_WORKER_LEASE_SECONDS=120
ANALYSIS_WORKER_QUICK_CHECK_INTERVAL_SECONDS=1800
ANALYSIS_JOB_RETRY_COOLDOWN_SECONDS=300
FOCUS_REVALIDATION_MAX_ROWS_PER_RUN=1000
FOCUS_REVALIDATION_MAX_SECONDS_PER_RUN=2
FOCUS_REVALIDATION_BATCH_SIZE=200
FOCUS_REVALIDATION_RESUME_INTERVAL_SECONDS=60
CALENDAR_ANALYSIS_PROMPT_VERSION=calendar-impact-v1
CALENDAR_ANALYSIS_SCHEMA_VERSION=calendar-impact-schema-v1
CALENDAR_LLM_MANUAL_ENABLED=false
CALENDAR_LLM_MAX_INFLIGHT=1
CALENDAR_LLM_MAX_QUEUED=10
CALENDAR_MAX_OUTPUT_TOKENS=16384
CALENDAR_LLM_DAILY_JOB_LIMIT=
CALENDAR_LLM_DAILY_OUTPUT_TOKEN_LIMIT=
ANTHROPIC_API_KEY=
GROK_API_KEY=
GROK_MODEL=grok-4
GROK_BASE_URL=https://api.x.ai/v1
OLLAMA_BASE_URL=http://host.docker.internal:11434

# X sentiment is a model-generated market scenario, not a live X data feed.
X_SENTIMENT_ENABLED=false
X_SENTIMENT_INTERVAL=21600
ANALYSIS_BATCH_SIZE=10
ANALYSIS_RETENTION_LIMIT=350
CALENDAR_ANALYSIS_CACHE_TTL=3600
CALENDAR_FETCH_INTERVAL_SECONDS=600

# Leave retention-day values blank to retain source records indefinitely.
NEWS_RETENTION_DAYS=
X_SENTIMENT_RETENTION_DAYS=
NEWS_ITEM_RETENTION_DAYS=
ANALYSIS_JOB_RETENTION_DAYS=
ANALYSIS_REVISION_RETENTION_DAYS=
STOCK_IMPACT_RETENTION_DAYS=
EVENT_GROUP_RETENTION_DAYS=
ANALYSIS_CYCLE_RETENTION_DAYS=
CALENDAR_REVISION_RETENTION_DAYS=
INTEGRATION_CHANGE_RETENTION_DAYS=
HOTSPOT_PREPARATION_RETENTION_DAYS=90
MARKET_FOCUS_COMPLETED_RETENTION_DAYS=365
MARKET_FOCUS_FAILED_RETENTION_DAYS=30
FOCUS_SNAPSHOT_RETENTION_DAYS=90
FOCUS_SNAPSHOT_FULL_RESOLUTION_DAYS=30
FOCUS_SNAPSHOT_DAILY_ROLLUP_ENABLED=true
EVENT_MEMBER_RETENTION_DAYS=90
PROJECTION_RETRY_RETENTION_DAYS=30
PROJECTION_RETRY_MAX_ATTEMPTS=6

# --- Storage and networking ---
DATABASE_URL=sqlite+aiosqlite:///data/macrolens.db
MACROLENS_DATA_DIR=
# Same-origin Docker deployment does not need CORS. For a separate frontend,
# list exact origins separated by commas; wildcard credentials are rejected.
CORS_ORIGINS=

# --- Option Pro remote integration ---
# Keep these blank until the two HTTPS servers and firewall allow-list are ready.
# The container default is /app/contracts/macrolens-option-pro-v2.json. Leave
# blank for automatic source-tree/runtime discovery.
MACROLENS_OPTION_PRO_CONTRACT_PATH=
OPTION_PRO_READ_KEY_ID=
OPTION_PRO_READ_SECRET=
OPTION_PRO_ACTION_KEY_ID=
OPTION_PRO_ACTION_SECRET=
OPTION_PRO_PREVIOUS_READ_SECRET=
OPTION_PRO_PREVIOUS_ACTION_SECRET=
# Required and fail-closed when either Integration key is configured.
OPTION_PRO_ALLOWED_CIDRS=
# Only the outer TLS proxy belongs here; blank means forwarded headers are ignored.
OPTION_PRO_TRUSTED_PROXY_CIDRS=
OPTION_PRO_SIGNATURE_CLOCK_SKEW_SECONDS=300
OPTION_PRO_NONCE_TTL_SECONDS=600
OPTION_PRO_SOURCE_STALE_AFTER_SECONDS=86400
OPTION_PRO_ALLOW_LOCAL_HTTP=false

# Pull-only focus context. Keep blank until option-pro HTTPS and HMAC are ready.
OPTION_PRO_FOCUS_BASE_URL=
OPTION_PRO_FOCUS_KEY_ID=
OPTION_PRO_FOCUS_SECRET=
OPTION_PRO_FOCUS_VERIFY_TLS=true
OPTION_PRO_FOCUS_CA_BUNDLE=
OPTION_PRO_FOCUS_INTERVAL_SECONDS=1800
OPTION_PRO_FOCUS_CONNECT_TIMEOUT_SECONDS=5
OPTION_PRO_FOCUS_READ_TIMEOUT_SECONDS=10
OPTION_PRO_FOCUS_TIMEOUT_SECONDS=20
OPTION_PRO_FOCUS_MAX_RESPONSE_BYTES=1048576
OPTION_PRO_FOCUS_MAX_ATTEMPTS=3
OPTION_PRO_FOCUS_RETRY_BACKOFF_SECONDS=0.25
OPTION_PRO_FOCUS_CIRCUIT_FAILURE_THRESHOLD=3
OPTION_PRO_FOCUS_CIRCUIT_RESET_SECONDS=60
